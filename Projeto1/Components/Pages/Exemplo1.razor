@page "/exemplo1"  
@rendermode InteractiveServer

<div class="alert alert-primary" role="alert">
@Alert
</div>

<form class="row g-2">

    <div class="col-md-6">
    <label for="nome">Nome</label>
    <input type="text" id="nome" class="form-control"  @bind-value="Nome"/>
    </div>

    <div class="col-md-6">
    <label for="cpf">CPF</label>
    <input type="tel" id="cpf" class="form-control" @bind-value="Cpf"/>
    </div>

    <div class="col-md-6">
    <label for="email">E-mail</label>
    <input type="email" id="email" class="form-control" @bind-value="Email"/>
    </div>

    <div class="col-md-6">
    <label for="senha">Senha</label>
    <input type="password" id="senha" class="form-control" @bind-value="Senha"/>
    </div>

    <div class="col-12">
    <button type="button" class="btn btn-primary d-block w-100" @onclick="Enviar">Enviar</button>
    </div>

</form>


@code {

    private string Alert = "Preencha o formulário e clique em Enviar.";

    private string Nome = "";
    private string Cpf = "";
    private string Email = "";
    private string Senha = "";

    private void Enviar()
    {
        if (string.IsNullOrEmpty(Nome))
        {
            Alert = "Por favor, preencha todos os campos.";
            return;
        }
        Alert = "Formulário enviado com sucesso!";
    }
}